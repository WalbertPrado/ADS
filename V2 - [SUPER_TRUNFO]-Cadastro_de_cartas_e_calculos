#include <stdio.h>
#include <locale.h>
#include <string.h>

int main() {
    setlocale(LC_ALL, "pt_BR.UTF-8");
    char estado1, estado2;
    char codigo1[4], codigo2[4];
    char nomecidade1[50], nomecidade2[50];
    int populacao1, populacao2;
    float area1, pib1, area2, pib2;
    int pontosturisticos1, pontosturisticos2;

    printf("Digite o estado (A-H): ");
    scanf(" %c", &estado1); 

    printf("Digite o código da carta (ex: %c01): ", estado1);
    scanf(" %s", codigo1);

    printf("Digite o nome da cidade: ");
    scanf(" %49[^\n]", nomecidade1);

    printf("População: ");
    scanf(" %d", &populacao1);

    printf("Área: ");
    scanf(" %f", &area1);

    printf("PIB: ");
    scanf(" %f", &pib1);

    printf("Pontos Turísticos: ");
    scanf(" %d", &pontosturisticos1);

    printf("\nCarta 1 registrada! Agora digite os dados da carta 2: \n\n");

   printf("Digite o estado (A-H): ");
    scanf(" %c", &estado2); 

    printf("Digite o código da carta (ex: %c01): ", estado2);
    scanf(" %s", codigo2);

    printf("Digite o nome da cidade: ");
    scanf(" %49[^\n]", nomecidade2);

    printf("População: ");
    scanf(" %d", &populacao2);

    printf("Área: ");
    scanf(" %f", &area2);

    printf("PIB: ");
    scanf(" %f", &pib2);

    printf("Pontos Turísticos: ");
    scanf(" %d", &pontosturisticos2);

    float densidade1 = populacao1 / area1;
    float densidade2 = populacao2 / area2;
    float pibper1 = pib1 / populacao1;
    float pibper2 = pib2 / populacao2;

    printf("\nCadastro finalizado! Segue os dados das cartas: \n\n --- Carta 1 ---\n\n");
    printf("Estado: %c\n", estado1);
    printf("Código: %s\n", codigo1);
    printf("Populacao: %d\n", populacao1);
    printf("Area: %.2f km²\n", area1);
    printf("PIB: %.2f bilhoes de reais\n", pib1);
    printf("Pontos Turisticos: %d\n", pontosturisticos1);
    printf("Densidade populacional: %.2f hab/km²\n", densidade1);
    printf("PIB per capita: %.2f reais\n", pibper1);

    printf("\n--- Carta 2 ---\n\n");
    printf("Estado: %c\n", estado2);
    printf("Codigo: %s\n", codigo2);
    printf("populacao: %d\n", populacao2);
    printf("Area: %.2f km²\n", area2);
    printf("PIB: %.2f bilhoes de reais\n", pib2);
    printf("Pontos turisticos: %d\n", pontosturisticos2);
    printf("Densidade populacional: %.2f hab/km²\n", densidade2);
    printf("PIB per capita: %.2f reais\n", pibper2);

    printf("\n\nObrigado por usar o cadastro de cartas do Super Trunfo! \n\nAté a próxima!\n");

    return 0;
}
